DOMAIN=munywele.co.ke
DOMAIN_EMAIL=admin@munywele.co.ke

SPRING_PROFILES_ACTIVE=prod

DIALECT=org.hibernate.dialect.MariaDB103Dialect
CLEAR_CHECKSUM=true
DB_URL=jdbc:mariadb://maria:3306/fuelrod
DB_USER=
DB_PASS=
DB_NAME=fuelrod
BLOG_DB_NAME=blog
DB_SERVICE=maria

JWT_SECRET=
JWT_TOKEN_VALIDITY=15552000
JWT_REFRESH_TOKEN_VALIDITY=15552000

DEFAULT_SENDER=false
SMS_API_USER=fuelrod
SMS_API_KEY=

SMS_API_USER_B=kambuigirls
SMS_API_KEY_B=

TEXT_SMS_API_KEY=

PUSH_BULLET_KEY=

SITE_DB=tsobu_site

OPT_OUT=STOP*456*9*5#
NO_QUEUE_WORDS=Token
DUPLICATE_WINDOW=5

THEME=flat
PLUGINS=dump-date tables-filter tinymce foreign-system dump-zip dump-alter

PORTAL_TAG=4.1.2
FUELROD_TAG=12.3.0
LEGACY_PORTAL=5.0.1

SPRING_DEBUG=false
TRACE=false
DEMO_MODE=false
VERIFY_CERT=false

# AKILIMO SECTION
AKILIMO_VERSION_TAG=7.2.0
AKILIMO_DB_URL=jdbc:mariadb://maria:3306/akilimo_db
AKILIMO_USER=
AKILIMO_DB_PASS=
PLUMBER_BASE=https://akilimo.org/plumber/
COMPUTE_TZ=v3/dst/recommendation/tz/compute
COMPUTE_NG=v3/dst/recommendation/ng/compute

## -- this is section for rate limiting
RATE_TYPE=hour
RATE_ENABLED=true
MAX_REQUESTS=1000

TZS_USD=2250
NGN_USD=360
KES_USD=103

#--  sms nesaging section
SMS_ENDPOINT=https://api.tsobu.co.ke
SMS_ENDPOINT=/v1/sms/single
SMS_USER=
SMS_PASS=
SMS_TOKEN=

# -- ONA data folder --
OUTPUT_PATH=/mnt/extra_storage/ona_data/

# --WORKING DIRECTORY --
WORK_DIR=/home/akilimo/services/tsobu/proxy/

AGWISE_DB_URL=
AGWISE_LOG_LEVEL=DEBUG

PG_ADMIN_EMAIL=
PG_ADMIN_PASS=
PG_PASS=

ANA_SECRET_kEY=
DJANGO_DEBUG=False
ANA_TAG=latest
ALLOWED_HOSTS=*
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,https://ana.akilimo.org


DRONE_GITHUB_CLIENT_ID=your-id
DRONE_GITHUB_CLIENT_SECRET=super-duper-secret
DRONE_RPC_SECRET=super-duper-secret
DRONE_SERVER_HOST=drone.company.com
